<Window x:Class="Lab4My.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Lab4My"
        mc:Ignorable="d"
        Title="MainWindow" Height="550" Width="1225" FontSize="28">
    <Grid x:Name="grid" ShowGridLines="True">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0">
            <Border.Background>
                <ImageBrush ImageSource="/MainImages/Fieldback.png"/>
            </Border.Background>
        </Border>
        <Button Content="Start" Grid.Row="1" Width="200" Margin="0 20 500 20"/>
        <Button Content="Reset" Grid.Row="1" Width="200" Margin="40 20 100 20"/>
        <Button Content="Bomb" Grid.Row="1" Width="200" Margin="500 20 100 20" Click="Buttondropbomb_Click" />
    </Grid>
</Window>
